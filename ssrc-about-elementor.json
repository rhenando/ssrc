                "editor": "<style>@media(max-width:768px){#ab-val-grid{grid-template-columns:repeat(2,1fr)!important}}@media(max-width:480px){#ab-val-grid{grid-template-columns:1fr!important}}</style><div id='ab-val-grid' style='display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(0,128,128,.08);border:1px solid rgba(0,128,128,.08);border-radius:16px;overflow:hidden;font-family:Inter,Playfair Display,sans-serif;'><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>01</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Integrity</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We uphold the highest ethical standards in every aspect of our work, ensuring transparency, impartiality, and trustworthiness across all outputs.</p></div><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>02</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Excellence</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We deliver high-quality, evidence-based results that meet international standards and consistently exceed client expectations.</p></div><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>03</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Innovation</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We embrace creativity and forward thinking, constantly evolving our methodologies to stay at the forefront of research and consulting.</p></div><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>04</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Collaboration</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We believe meaningful impact is achieved through partnership, working closely with clients, communities, and all stakeholders.</p></div><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>05</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Accountability</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We take responsibility for the accuracy, reliability, and impact of our work, maintaining professionalism in every project.</p></div><div style='background:#003366;padding:36px 28px;' class='s-vc'><div style='font-size:11px;font-weight:800;color:rgba(102,212,200,.25);letter-spacing:3px;margin-bottom:16px;'>06</div><h4 style='font-size:18px;font-weight:700;color:#fff;margin-bottom:10px;'>Empowerment</h4><p style='font-size:13px;color:rgba(255,255,255,.45);line-height:1.85;margin:0;'>We build capacity, share knowledge, and enable others to make informed, data-driven decisions that contribute to positive change.</p></div></div><style>.s-vc{transition:background .4s ease;cursor:default}.s-vc:hover{background:#003d5c}</style>"
