adient(270deg,#003366 0%,transparent 40%);'></div><div style='position:absolute;top:30px;right:30px;bottom:30px;left:30px;border:1px solid rgba(0,128,128,.2);border-radius:8px;pointer-events:none;'></div><div style='position:absolute;bottom:30px;left:30px;background:rgba(0,51,102,.7);backdrop-filter:blur(10px);padding:10px 18px;border-radius:6px;border:1px solid rgba(255,255,255,.06);'><span style='font-size:10px;color:rgba(255,255,255,.4);letter-spacing:1px;'>دمشق، سوريا</span></div></div></div><div style='position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,128,128,.3),transparent);'></div></div>"
