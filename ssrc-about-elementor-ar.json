                "editor": "<div dir='rtl' class='s-lift s-glow' style='background:#fff;border-radius:16px;overflow:hidden;font-family:Cairo,Arial,sans-serif;border:1px solid rgba(0,128,128,.12);position:relative;'><div class='s-img-rv' style='height:240px;position:relative;'><img src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&q=80' style='width:100%;height:100%;object-fit:cover;display:block;'><div style='position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,51,102,.1) 0%,rgba(0,51,102,.8) 100%);'></div><div style='position:absolute;bottom:28px;right:28px;'><div style='font-size:11px;font-weight:700;color:#66d4c8;letter-spacing:2px;margin-bottom:6px;'>MISSION</div><div style='font-size:26px;font-weight:900;color:#fff;line-height:1.2;'>من رسالتنا<br>اليومية</div></div></div><div style='padding:28px 28px 32px;'><p style='font-size:14.5px;color:#6b7a8d;line-height:1.9;margin:0;'>تقديم رؤى موثوقة وقابلة للتطبيق تساعد المؤسسات على فهم بيئاتها واتخاذ قرارات أفضل مبنية على الأدلة والتحليل الصارم. تلتزم SSRC بالجودة والنزاهة في كل مشروع وكل علاقة استشارية.</p></div><div style='position:absolute;top:0;right:0;width:4px;height:60px;background:linear-gradient(180deg,#008080,transparent);border-radius:0 0 4px 0;'></div></div>"
